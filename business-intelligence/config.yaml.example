server:
  port: 8093

# Machine-to-machine authentication (required for /machine/** endpoints)
# Environment variables: COMMON_AOP_MACHINE_USERNAME, COMMON_AOP_MACHINE_PASSWORD
common:
  aop:
    machine:
      username: "${COMMON_AOP_MACHINE_USERNAME:}"
      password: "${COMMON_AOP_MACHINE_PASSWORD:}"

business-intelligence:
  # Comma-delimited origin patterns for browser access.
  cors-origin: "*"

  runtime:
    # Base directory for source Excel files.
    base-dir: "./data"
    # Cache aggregated snapshot data in memory between requests.
    cache-enabled: true
    # Optional override for the BI service URL used by the enhanced export script.
    # Leave empty to fall back to http://localhost:<server.port>.
    export-bi-url: ""
  logging:
    access-log-enabled: true

logging:
  level:
    root: INFO
    com.huawei.opsfactory.businessintelligence: INFO
    org.springframework: WARN
