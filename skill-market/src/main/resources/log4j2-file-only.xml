<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
    <Properties>
        <Property name="LOG_PATTERN">%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [skill-market] [%thread] [%X{requestId}] %logger{36} - %msg%n%throwable</Property>
        <Property name="LOG_DIR">logs</Property>
    </Properties>

    <Appenders>
        <RollingFile name="File"
                     fileName="${LOG_DIR}/skill-market.log"
                     filePattern="${LOG_DIR}/skill-market-%d{yyyy-MM-dd}-%i.log.gz">
            <PatternLayout pattern="${LOG_PATTERN}"/>
            <Policies>
                <TimeBasedTriggeringPolicy/>
                <SizeBasedTriggeringPolicy size="50MB"/>
            </Policies>
            <DefaultRolloverStrategy max="30"/>
        </RollingFile>
    </Appenders>

    <Loggers>
        <Root level="INFO">
            <AppenderRef ref="File"/>
        </Root>
    </Loggers>
</Configuration>
